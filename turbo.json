{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "install": {
            "cache": false
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                "build/**",
                "out/**"
            ]
        },
        "test": {
            "dependsOn": [
                "^test"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "outputs": []
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ],
            "outputs": []
        }
    }
}
